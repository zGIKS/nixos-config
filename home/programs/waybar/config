{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 4,
  "fixed-center": true,
  "modules-left": ["custom/launcher-settings", "tray"],
  "modules-center": ["sway/workspaces"],
  "modules-right": [
    "network",
    "pulseaudio",
    "bluetooth",
    "backlight",
    "battery",
    "custom/notifications",
    "clock"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "sort-by-number": true,
    "format-icons": {
      "1": "一",
      "2": "二",
      "3": "三",
      "4": "四",
      "5": "五",
      "6": "六",
      "7": "七",
      "8": "八",
      "9": "九"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": [],
      "7": [],
      "8": [],
      "9": []
    },
    "format": "{icon}"
  },
  "network": {
    "format-wifi": "󰤨",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰤭",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)"
  },
  "bluetooth": {
    "format": "󰂯",
    "format-connected": "󰂱",
    "tooltip-format": "{device_alias}"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [ "󰃞", "󰃟", "󰃠" ],
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-icons": [ "󰕿", "󰖀", "󰕾" ],
    "format-muted": "󰖁",
    "tooltip": false
  },
  "battery": {
    "bat": "CMB0",
    "adapter": "ADP1",
    "interval": 2,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄 {capacity}%",
    "format-full": "󰁹 100%",
    "format-warning": "󰁼 {capacity}%",
    "format-critical": "󰂎 {capacity}%",
    "format-time": "{H}h {m}m",
    "tooltip-format": "{time}",
    "format-icons": [ "󰂎", "󰁺", "󰁼", "󰁾", "󰂀", "󰂂", "󰁹" ]
  },
  "clock": {
    "format": "󰥔 {:%I:%M %p}",
    "tooltip-format": "{:%A, %B %d, %Y}"
  },
  "tray": {
    "icon-size": 16,
    "show-passive-items": true,
    "spacing": 10
  },
  "custom/notifications": {
    "format": "󰍡",
    "tooltip": false
  },
  "custom/launcher-settings": {
    "format": "",
    "on-click": "sh ~/.config/wofi/launcher.sh",
    "tooltip": false
  }
}
