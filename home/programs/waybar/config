{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 4,
  "fixed-center": true,
  "modules-left": ["custom/power", "tray"],
  "modules-center": ["sway/workspaces"],
  "modules-right": [
    "network",
    "pulseaudio",
    "bluetooth",
    "backlight",
    "battery",
    "custom/notifications",
    "clock"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "sort-by-number": true,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": []
    },
    "format": "{name}"
  },
  "network": {
    "format-wifi": "󰤨",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰤭",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)"
  },
  "bluetooth": {
    "format": "󰂯",
    "format-connected": "󰂱",
    "tooltip-format": "{device_alias}"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [ "󰃞", "󰃟", "󰃠" ],
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-icons": [ "󰕿", "󰖀", "󰕾" ],
    "format-muted": "󰖁",
    "tooltip": false
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-icons": [ "󰁺", "󰁼", "󰁾", "󰂀", "󰂂" ]
  },
  "clock": {
    "format": "󰥔 {:%I:%M %p}",
    "tooltip-format": "{:%A, %B %d, %Y}"
  },
  "tray": {
    "icon-size": 16,
    "show-passive-items": true,
    "spacing": 10
  },
  "custom/notifications": {
    "format": "󰍡",
    "tooltip": false
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "wlogout",
    "tooltip": false
  }
}
