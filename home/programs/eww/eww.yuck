(defpoll season :interval "24h" "date +%m | awk '{if ($1 >= 3 && $1 <= 5) print \"Autumn 🍂\"; else if ($1 >= 6 && $1 <= 8) print \"Winter ❄️\"; else if ($1 >= 9 && $1 <= 11) print \"Spring 🌸\"; else print \"Summer ☀️\"}'")
(defpoll location :interval "24h" "echo \"$(timedatectl show --property=Timezone --value | awk -F'/' '{print $2}'), PET (UTC-05)\"")

(include "./widgets/calendar.yuck")
(include "./widgets/power-menu.yuck")
