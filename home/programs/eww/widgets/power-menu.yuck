(defwindow power_menu
  :monitor 0
  :stacking "overlay"
  :focusable "ondemand"
  :exclusive false
  :geometry (geometry :x "0%" :y "0%" :width "100%" :height "100%" :anchor "center")
  (eventbox :onclick "sh ~/.config/eww/scripts/power-menu/close.sh"
    (box :class "power-menu-backdrop" :orientation "v" :space-evenly false :halign "center" :valign "center"
      (eventbox :onclick "return true"
        (box :class "power-menu-card panel-card" :orientation "v" :space-evenly false :spacing 24
          (box :class "power-menu-container" :orientation "h" :spacing 16
            (button
              :class "power-menu-button"
              :onclick "sh -lc 'sh ~/.config/eww/scripts/power-menu/close.sh; swaymsg exit'"
              (box :orientation "v" :spacing 12 :halign "center" :valign "center"
                (label :class "power-menu-button-icon" :text "󰍃")
                (label :class "power-menu-button-label" :text "Logout")))
            (button
              :class "power-menu-button"
              :onclick "sh -lc 'sh ~/.config/eww/scripts/power-menu/close.sh; systemctl reboot'"
              (box :orientation "v" :spacing 12 :halign "center" :valign "center"
                (label :class "power-menu-button-icon" :text "󰜉")
                (label :class "power-menu-button-label" :text "Reboot")))
            (button
              :class "power-menu-button"
              :onclick "sh -lc 'sh ~/.config/eww/scripts/power-menu/close.sh; systemctl poweroff'"
              (box :orientation "v" :spacing 12 :halign "center" :valign "center"
                (label :class "power-menu-button-icon" :text "󰐥")
                (label :class "power-menu-button-label" :text "Shutdown")))))))))
