(defpoll bluetooth_panel_content :interval "5s" `bash ~/.config/eww/components/bluetooth/status.sh panel`)

(defwindow bluetooth-panel
  :monitor 0
  :stacking "overlay"
  :focusable true
  :exclusive false
  :geometry (geometry
    :x "16px"
    :y "40px"
    :anchor "top right"
    :width "420px"
    :height "560px")
  (literal :content bluetooth_panel_content))
